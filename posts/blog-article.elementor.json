            {
              "id": "35024cb",
              "elType": "widget",
              "settings": {
                "html": "<div class=\"lg-art-footer\">\n  <div class=\"lg-reactions\">\n    <span class=\"lab\">האם המאמר היה לכם מועיל?</span>\n    <button class=\"lg-ibtn dn\" aria-label=\"לא עזר\" onclick=\"this.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('on'));this.classList.add('on')\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3z\"/></svg></button>\n    <button class=\"lg-ibtn up\" aria-label=\"עזר\" onclick=\"this.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('on'));this.classList.add('on')\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3z\"/></svg></button>\n  </div>\n  <div class=\"lg-share\">\n    <span class=\"lab\">שתפו את המאמר:</span>\n    <a class=\"lg-ibtn\" aria-label=\"פייסבוק\" href=\"https://www.facebook.com/sharer/sharer.php?u=\" target=\"_blank\" rel=\"noopener\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z\"/></svg></a>\n    <a class=\"lg-ibtn\" aria-label=\"וואטסאפ\" href=\"https://wa.me/?text=\" target=\"_blank\" rel=\"noopener\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.5 0 .19 5.3.19 11.84a11.79 11.79 0 0 0 1.58 5.92L0 24l6.4-1.68a11.83 11.83 0 0 0 5.64 1.44h.01c6.54 0 11.85-5.3 11.85-11.84a11.78 11.78 0 0 0-3.38-8.44z\"/></svg></a>\n    <button class=\"lg-ibtn\" aria-label=\"העתק קישור\" onclick=\"navigator.clipboard.writeText(location.href)\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg></button>\n  </div>\n</div>\n<style>\n.lg-art-footer{font-family:'Rubik',sans-serif;margin-top:32px;border:1px solid #e9e5f0;background:#f9f6fd;border-radius:12px;padding:18px 22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}\n.lg-reactions,.lg-share{display:flex;align-items:center;gap:12px}\n.lg-reactions .lab,.lg-share .lab{font-size:14px;color:#374151;font-weight:500}\n.lg-ibtn{width:38px;height:38px;border-radius:999px;background:#fff;border:1px solid #e9e5f0;display:grid;place-items:center;color:#6b7280;transition:all .15s;cursor:pointer;text-decoration:none}\n.lg-ibtn:hover{color:#7434DB;border-color:#D3BEF4;background:#f9f6fd}\n.lg-ibtn.up.on,.lg-ibtn.up:hover{color:#2BA776;border-color:#BFE5D2;background:#EFFAF4}\n.lg-ibtn.dn.on,.lg-ibtn.dn:hover{color:#C25C5C;border-color:#EBC8C8;background:#FAEFEF}\n</style>"
