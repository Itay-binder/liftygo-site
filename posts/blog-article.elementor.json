            {
              "id": "870cb0e",
              "elType": "widget",
              "settings": {
                "html": "<div class=\"lg-art-top\">\n  <span class=\"lg-tag\">טיפים להובלה</span>\n  <h1>איך לבחור מוביל אמין: <span class=\"hl\">המדריך המלא</span> להובלה בראש שקט</h1>\n  <div class=\"lg-meta\">\n    <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg> צוות LiftyGo</span>\n    <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg> 25 במאי 2024</span>\n    <span><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg> 15 דקות קריאה</span>\n  </div>\n  <div class=\"lg-hero\">\n    <div class=\"lg-hero-ph\">\n      <svg viewBox=\"0 0 24 18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\".75\" y=\"3\" width=\"13.5\" height=\"10\" rx=\"1\"/><path d=\"M14.25 6h4l2.5 2.5V13h-6.5V6z\"/><circle cx=\"4.5\" cy=\"14.5\" r=\"1.5\"/><circle cx=\"17.5\" cy=\"14.5\" r=\"1.5\"/></svg>\n      תמונת הכותרת — moving truck hero\n    </div>\n  </div>\n</div>\n<style>\n.lg-art-top{font-family:'Rubik',sans-serif}\n.lg-tag{display:inline-block;background:linear-gradient(135deg,#D3BEF4,#E2CCFF);color:#2D2152;font-size:13px;font-weight:700;padding:6px 16px;border-radius:999px;letter-spacing:.3px}\n.lg-art-top h1{font-size:clamp(26px,3.4vw,36px);line-height:1.25;margin:18px 0 22px;color:#2D2152;font-weight:800;letter-spacing:-.01em}\n.lg-art-top h1 .hl{background:linear-gradient(135deg,#D3BEF4,#E2CCFF);color:#2D2152;border-radius:10px;padding:2px 10px;display:inline}\n.lg-meta{display:flex;gap:22px;align-items:center;color:#6b7280;font-size:14px;padding-bottom:22px;flex-wrap:wrap}\n.lg-meta span{display:inline-flex;align-items:center;gap:6px}\n.lg-meta svg{color:#8e8899}\n.lg-hero{width:100%;aspect-ratio:16/9;border-radius:12px;background:linear-gradient(135deg,#E9DEF7,#D8C8EC);display:grid;place-items:center;color:#7434DB;margin-bottom:28px;overflow:hidden}\n.lg-hero-ph{text-align:center;font-family:ui-monospace,Menlo,monospace;font-size:13px;color:rgba(95,63,146,.65)}\n.lg-hero-ph svg{width:90px;height:70px;opacity:.55;margin:0 auto 10px;display:block}\n</style>"
              },
