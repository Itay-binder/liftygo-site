            {
              "id": "0e38065",
              "elType": "widget",
              "settings": {
                "html": "<div class=\"lg-article-card\"><style>.lg-article-card{background:#fff;border-radius:18px;box-shadow:0 4px 16px rgba(95,63,146,.06),0 1px 2px rgba(31,27,46,.04);padding:36px 40px 0}@media(max-width:640px){.lg-article-card{padding:24px 22px 0}}</style>"
