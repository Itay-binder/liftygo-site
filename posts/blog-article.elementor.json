                "html": "<nav class=\"lg-site-nav\">\n  <div class=\"lg-site-nav-inner\">\n    <a href=\"https://liftygo.co.il/\" class=\"lg-logo\">Lifty<span>Go</span></a>\n    <div class=\"lg-nav-menu\">\n      <a href=\"https://liftygo.co.il/blog/\" class=\"active\">בלוג</a>\n      <a href=\"https://liftygo.co.il/joinus/\">להצטרף כמוביל</a>\n      <a href=\"https://liftygo.co.il/\">לקבלת מחירי הובלה</a>\n    </div>\n    <a href=\"https://liftygo.co.il/\" class=\"lg-nav-cta\">לקבלת מחירי הובלה ←</a>\n  </div>\n</nav>\n<style>\n.lg-site-nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(163,121,231,.12);font-family:'Rubik',sans-serif}\n.lg-site-nav-inner{max-width:1240px;margin:0 auto;display:flex;align-items:center;gap:40px;padding:14px 24px}\n.lg-logo{font-size:22px;font-weight:800;color:#7434DB;letter-spacing:-.3px;text-decoration:none}\n.lg-logo span{color:#A379E7}\n.lg-nav-menu{display:flex;gap:32px;align-items:center;flex:1}\n.lg-nav-menu a{font-size:15px;font-weight:500;color:#374151;padding:6px 0;position:relative;text-decoration:none;transition:color .15s}\n.lg-nav-menu a:hover{color:#7434DB}\n.lg-nav-menu a.active{color:#7434DB;font-weight:700}\n.lg-nav-menu a.active::after{content:\"\";position:absolute;bottom:-2px;right:0;left:0;height:2px;background:#7434DB;border-radius:2px}\n.lg-nav-cta{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#A379E7,#7434DB);color:#fff;font-size:14px;font-weight:700;padding:11px 22px;border-radius:10px;text-decoration:none;transition:opacity .2s,transform .1s}\n.lg-nav-cta:hover{opacity:.9}\n.lg-nav-cta:active{transform:translateY(1px)}\n@media (max-width:640px){.lg-site-nav-inner{padding:14px 18px;gap:14px;flex-wrap:wrap}.lg-nav-menu{gap:18px;order:3;width:100%}}\n</style>"
