            {
              "id": "078c00d",
              "elType": "widget",
              "settings": {
                "title": "למה חשוב לבחור מוביל אמין?",
                "header_size": "h2",
                "align": "right",
                "title_color": "#2D2152",
                "typography_typography": "custom",
                "typography_font_family": "Rubik",
                "typography_font_weight": "700",
