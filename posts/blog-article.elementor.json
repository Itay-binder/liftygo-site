            {
              "id": "6b1da85",
              "elType": "widget",
              "settings": {
                "editor": "<p>בחירה נכונה של מוביל יכולה לעשות את כל ההבדל. קחו את הזמן, בדקו היטב ותהיו בראש שקט ביום ההובלה. צוות LiftyGo כאן כדי לעזור — אנחנו מחברים אתכם רק למובילים מאומתים ומדורגים.</p>",
                "text_color": "#374151",
                "typography_typography": "custom",
                "typography_font_family": "Rubik",
                "typography_font_size": {
                  "unit": "px",
                  "size": 16,
